{
	"info": {
		"_postman_id": "76e93e2b-23f2-4a0f-90db-2b5a1f11e3b5",
		"name": "RustFS Local API",
		"description": "API collection for the local RustFS file upload system.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Generate Upload URL",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"filename\": \"example.txt\",\n    \"mimetype\": \"text/plain\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/upload-url",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"upload-url"
					]
				},
				"description": "Generates a pre-signed URL to securely upload a file directly to RustFS."
			},
			"response": []
		},
		{
			"name": "2. Upload File (Direct to RustFS)",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "text/plain"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "Hello RustFS from Postman!"
				},
				"url": {
					"raw": "{{UPLOAD_URL}}",
					"host": [
						"{{UPLOAD_URL}}"
					]
				},
				"description": "After calling 'Generate Upload URL', copy the returned `url` and paste it here as the request URL. Ensure the Content-Type header matches the mimetype you requested."
			},
			"response": []
		},
		{
			"name": "3. Save File Metadata",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"filename\": \"example.txt\",\n    \"key\": \"<paste_key_from_step_1>\",\n    \"size\": 26,\n    \"mimetype\": \"text/plain\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/metadata",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"metadata"
					]
				},
				"description": "Saves the file details to PostgreSQL after a successful upload to RustFS."
			},
			"response": []
		},
		{
			"name": "4. List All Files",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/files",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"files"
					]
				},
				"description": "Retrieves the list of all files and their metadata from PostgreSQL."
			},
			"response": []
		},
		{
			"name": "5. Generate Download URL",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/download-url/:id",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"download-url",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "<paste_id_from_step_3_or_4>"
						}
					]
				},
				"description": "Generates a pre-signed URL to securely download a file from RustFS based on its database ID."
			},
			"response": []
		}
	]
}
